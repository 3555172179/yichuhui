# 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# Cloudflare 账户 ID (可选，用于自动配置)
# CLOUDFLARE_ACCOUNT_ID=your-account-id

# API Token (可选，用于自动化部署)
# CLOUDFLARE_API_TOKEN=your-api-token

# 环境
NODE_ENV=production

# 站点配置
SITE_URL=https://yichuhui.your-domain.com
SITE_NAME=Yichuhui (Zibo) Refrigeration Equipment Co., Ltd.

# 联系信息
CONTACT_EMAIL=info@yichuhui.com
SALES_EMAIL=sales@yichuhui.com
PHONE=+86-533-XXXXXXX

# 其他配置
TIMEZONE=Asia/Shanghai
