{
  "$schema": "https://developers.cloudflare.com/pages/platform/schemas-configuration/v1",
  "build": {
    "command": "npm run build",
    "destination": "public"
  },
  "build_configurations": [
    {
      "name": "production"
    }
  ],
  "compatibility_flags": [],
  "compatibility_date": "2024-01-01",
  "env": {
    "production": {}
  },
  "functions": {},
  "headers": [
    {
      "source": "*.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "*.css",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "*.svg",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "*.woff2",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "navigation": [],
  "pages_build_output_dir": "public",
  "redirects": [
    {
      "from": "/about",
      "status": 200,
      "to": "/about.html"
    },
    {
      "from": "/products",
      "status": 200,
      "to": "/products.html"
    },
    {
      "from": "/contact",
      "status": 200,
      "to": "/contact.html"
    }
  ],
  "routes": [
    {
      "pattern": "/*",
      "custom_domain": ["yichuhui.pages.dev"]
    }
  ],
  "rules": [],
  "service_bindings": [],
  "trailing_slash": "auto",
  "web_analytics": {}
}
